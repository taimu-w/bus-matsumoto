# docker compose 用の環境変数ファイル。
# 使い方: このファイルを .env としてコピーし、必要に応じて値を編集してください。
#   cp .env.example .env
# docker-compose.yml が自動的にこの .env を読み込みます（変数展開 & backendコンテナへの注入）。

# ---- PostgreSQL（dbコンテナ） ----
POSTGRES_DB=bus_realtime
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---- バックエンド接続情報（backendコンテナ。PGHOSTはcompose上のサービス名 "db" を指す） ----
PGHOST=db
PGPORT=5432
PGDATABASE=bus_realtime
PGUSER=postgres
PGPASSWORD=postgres
PORT=3000

# ---- リアルタイム位置情報取得（既存GASと同一設定） ----
LOCATION_FEED_URL=https://dashboard.wakoticket.net/information/alpicokotsu/latlon.csv
TARGET_EXTRA_ID=01h9j06f82mw3wvnddsbs4z7fs

# ---- 判定しきい値・運用パラメータ ----
STOP_RADIUS_METERS=120
START_AREA_RADIUS_METERS=150
DEPARTURE_OFFSET_METERS=200
END_AREA_RADIUS_METERS=150
SCHEDULE_MATCH_BEFORE_MIN=10
SCHEDULE_MATCH_AFTER_MIN=10
VEHICLE_MAX_AGE_MIN=120
GPS_FRESHNESS_MIN=15
NIGHT_START=23:00
NIGHT_END=05:45
POLL_INTERVAL_SECONDS=60
ETA_BLEND_WEIGHT=0.55
