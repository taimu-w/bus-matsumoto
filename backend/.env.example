# PostgreSQL接続情報
PGHOST=localhost
PGPORT=5432
PGDATABASE=bus_realtime
PGUSER=postgres
PGPASSWORD=postgres

# サーバーポート
PORT=3000

# リアルタイム位置情報取得先（既存GASと同一のURL・車両フィルタIDを使用すること）
LOCATION_FEED_URL=https://dashboard.wakoticket.net/information/alpicokotsu/latlon.csv
TARGET_EXTRA_ID=01h9j06f82mw3wvnddsbs4z7fs

# バス停通過判定の許容半径（メートル）。GAS版の緯度経度レンジ設定に相当。
STOP_RADIUS_METERS=120
# 営業開始エリア判定の半径（メートル）。始発バス停付近のこの範囲に入ったら営業開始とみなす。
START_AREA_RADIUS_METERS=150
# 出発判定：営業開始エリア中心からこの距離以上離れたら「出発済」とみなす（メートル）。
DEPARTURE_OFFSET_METERS=200
# 運行終了エリア（終点：松本バスターミナル）の判定半径（メートル）
END_AREA_RADIUS_METERS=150
# 運行予定照合の許容範囲（分）：出発時刻の前後何分まで時刻表の便とみなすか
SCHEDULE_MATCH_BEFORE_MIN=10
SCHEDULE_MATCH_AFTER_MIN=10
# 作成から何分経過した車両シート（＝データ）を強制終了するか
VEHICLE_MAX_AGE_MIN=120
# GPSデータの有効期限（分）：これより古いGPS点は通過判定に使わない
GPS_FRESHNESS_MIN=15
# 深夜運行停止時間帯
NIGHT_START=23:00
NIGHT_END=05:45

# ポーリング間隔（秒）
POLL_INTERVAL_SECONDS=60
