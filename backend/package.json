{
  "name": "bus-realtime-backend",
  "version": "1.0.0",
  "description": "松本ぐるっとバス 横田信大循環線 リアルタイム運行管理システム バックエンド",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
